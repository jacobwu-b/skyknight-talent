dist/
build/
out/
coverage/
*.lcov
.nyc_output/

# Dependencies (pick what applies to your stack — leave the rest)
node_modules/
.pnpm-store/
__pycache__/
*.pyc
.venv/
venv/
.tox/
target/
vendor/

# Test artefacts
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local agent state — never commit
.claude/local/
.claude/sessions/
