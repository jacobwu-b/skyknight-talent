# Secrets — never commit. Use .env.example as the schema.
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs / temp
*.log
*.tmp
*.pid
.cache/
tmp/
temp/

