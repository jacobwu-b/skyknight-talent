# Every env var the app reads MUST appear here.
# When you add or remove an env var in code, update this file in the same PR.
# Values here are placeholders — never commit real secrets.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
APP_URL=http://localhost:3000

# --- Database ---
# Supabase Postgres connection string. Daily PITR backups, 30-day retention.
DATABASE_URL=postgres://user:password@localhost:5432/skyknight

# --- Session ---
# Signed cookie for the simulated profile picker (spec 0001). Generate a strong random string.
SESSION_SECRET=

# --- Postmark: outbound transactional ---
# Duplicate-outreach alerts (spec 0007) and Monday digest (spec 0008).
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_ADDRESS=search@skyknightcapital.com

# --- Postmark: inbound webhook ---
# Inbound mail to search@ is parsed at /api/inbound (spec 0006).
POSTMARK_INBOUND_WEBHOOK_SECRET=
INBOUND_MAILBOX_ADDRESS=search@skyknightcapital.com

# --- Vercel Cron ---
# Shared secret protecting the Monday digest endpoint (spec 0008).
CRON_SECRET=
