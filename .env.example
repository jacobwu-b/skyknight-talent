# Every env var the app reads MUST appear here.
# When you add or remove an env var in code, update this file in the same PR.
# Values here are placeholders — never commit real secrets.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# --- Database ---
# PostgreSQL connection string. Daily backups with 30-day retention.
DATABASE_URL=postgres://user:password@localhost:5432/skyknightdb

# --- Microsoft Entra ID (SSO) ---
# OAuth 2.0 via Microsoft Entra ID. Partners and Associates authenticate here.
# Get these from your Azure app registration in the SkyKnight tenant.
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Email Ingestion (BCC Workflow) ---
# Microsoft Graph API credentials for reading the shared BCC mailbox.
# Partners BCC search@skyknightcapital.com; the app parses inbound mail.
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
BCC_MAILBOX_ADDRESS=search@skyknightcapital.com

# --- Session / Security ---
# For signed cookies or session tokens. Generate a strong random string.
SESSION_SECRET=
